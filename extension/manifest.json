{
  "manifest_version": 3,
  "name": "Bienvenida Simple",
  "version": "1.0",
  "description": "Muestra un mensaje de bienvenida",
  "action": {
    "default_popup": "htmls/popup.html"
  },
  "background": {
    "scripts": ["htmls/background.js"]
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"]
}
